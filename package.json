{
  "name": "coral",
  "version": "0.12.0",
  "description": "A local-first CLI/TUI coding agent for Ollama",
  "type": "module",
  "exports": {},
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggfincke/coral.git"
  },
  "bugs": {
    "url": "https://github.com/ggfincke/coral/issues"
  },
  "homepage": "https://github.com/ggfincke/coral#readme",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "coral": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "node node_modules/typescript-7/bin/tsc",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli/main.js',0o755)\"",
    "typecheck": "node node_modules/typescript-7/bin/tsc --noEmit",
    "typecheck:scripts": "node node_modules/typescript-7/bin/tsc -p tsconfig.scripts.json",
    "dev": "tsx src/cli/main.tsx",
    "start": "node dist/cli/main.js",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "npm run clean && npm run build",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "bench:compaction": "tsx tests/scripts/bench-compaction.ts",
    "eval": "tsx tests/scripts/eval/run.ts",
    "check:dev-tools": "node scripts/check-dev-tools.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "test:watch": "node --import tsx --test --watch 'tests/**/*.test.ts'",
    "comment-style:check": "python3 scripts/check-comment-style.py --check --root . --python-root scripts --python-root tests/scripts",
    "comment-style:fix": "python3 scripts/check-comment-style.py --fix --root . --python-root scripts --python-root tests/scripts",
    "lint": "npm run comment-style:check && eslint .",
    "lint:fix": "npm run comment-style:fix && eslint --fix .",
    "sessions:analyze": "uv run python scripts/analyze-sessions.py",
    "reference:inventory": "uv run python scripts/mine-reference.py",
    "check:changelog": "node scripts/check-changelog.mjs",
    "format": "prettier --write . && eslint --fix . && npm run comment-style:fix",
    "format:check": "prettier --check . && npm run lint",
    "version": "npm run check:changelog && git add CHANGELOG.md"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-brace-style"
    ],
    "braceStyle": "allman",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 80,
    "arrowParens": "always"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "^12.10.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "ink": "^7.0.6",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "string-width": "^8.2.2",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vscode-jsonrpc": "^9.0.1",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-brace-style": "^0.10.2",
    "tsx": "^4.23.0",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.62.1",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
