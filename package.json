{
  "name": "coral",
  "version": "0.11.0",
  "description": "A CLI/TUI coding agent for Ollama",
  "type": "module",
  "bin": {
    "coral": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "dev": "tsx src/cli/main.tsx",
    "start": "node dist/cli/main.js",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "bench:compaction": "tsx tests/scripts/bench-compaction.ts",
    "eval": "tsx tests/scripts/eval/run.ts",
    "check:dev-tools": "node scripts/check-dev-tools.mjs",
    "test:watch": "node --import tsx --test --watch 'tests/**/*.test.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "sessions:analyze": "uv run python scripts/analyze-sessions.py",
    "reference:inventory": "uv run python scripts/mine-reference.py",
    "check:changelog": "node scripts/check-changelog.mjs",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && npm run lint",
    "version": "npm run check:changelog && git add CHANGELOG.md"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-brace-style"
    ],
    "braceStyle": "allman",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 80,
    "arrowParens": "always"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "ink": "^7.0.6",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-brace-style": "^0.10.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
