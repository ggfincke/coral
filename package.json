{
  "name": "coral",
  "version": "0.9.0",
  "description": "A CLI/TUI coding agent for Ollama",
  "type": "module",
  "bin": {
    "coral": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/main.tsx",
    "start": "node dist/cli/main.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check:changelog": "node scripts/check-changelog.mjs",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && eslint .",
    "version": "npm run check:changelog && git add CHANGELOG.md"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-brace-style"
    ],
    "braceStyle": "allman",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 80,
    "arrowParens": "always"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "marked": "^17.0.6",
    "react": "^18.3.1",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.18",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-brace-style": "^0.10.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0"
  }
}
