{
  "name": "coral",
  "version": "0.0.1",
  "description": "A CLI/TUI coding agent for Ollama",
  "type": "module",
  "bin": {
    "coral": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/main.tsx",
    "start": "node dist/cli/main.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.6",
    "react": "^18.3.1",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
